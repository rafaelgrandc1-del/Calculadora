rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Users (Sellers and Admins) collection config - public CRUD for simple persistence
    match /users/{userId} {
      allow read, write: if true;
    }

    // Product Costs configuration settings
    match /productCosts/{costId} {
      allow read, write: if true;
    }

    // Orders synchronized across sessions
    match /orders/{orderId} {
      allow read, write: if true;
    }
  }
}
